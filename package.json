{
  "name": "temporals-nl",
  "version": "0.0.2",
  "type": "module",
  "description": "Natural-language date parsing extension for temporals.",
  "main": "index.mjs",
  "exports": {
    ".": "./index.mjs"
  },
  "files": [
    "index.mjs",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "example": "node examples/basic.mjs",
    "examples": "for f in examples/*.mjs; do echo \"# $f\"; node \"$f\" >/dev/null || exit 1; done",
    "docs": "typedoc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "temporals",
    "natural-language",
    "date",
    "parse",
    "chrono"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnhenry/temporals-nl.git"
  },
  "homepage": "https://github.com/johnhenry/temporals-nl#readme",
  "dependencies": {
    "temporal-polyfill": "^1.0.1",
    "temporals": "0.0.x"
  },
  "devDependencies": {
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}
